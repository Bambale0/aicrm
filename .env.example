# AICRM Production Environment Configuration
# Copy this file to .env and fill in the actual values

# Database Configuration
POSTGRES_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql+psycopg2://aicrm_user:your_password_here@localhost:5432/aicrm

# Security & Authentication
SECRET_KEY=your_very_long_random_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
AVITO_CLIENT_ID=your_avito_client_id_here
AVITO_CLIENT_SECRET=your_avito_client_secret_here

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your_app_password_here
FROM_EMAIL=noreply@chillcreative.ru

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AI Configuration
DEFAULT_AI_MODEL=gpt-3.5-turbo
AI_REQUEST_TIMEOUT=30
MAX_AI_REQUESTS_PER_MINUTE=60

# System Configuration
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# CORS & Frontend
ALLOW_ORIGINS=https://dev.chillcreative.ru,https://chillcreative.ru
CORS_ALLOW_CREDENTIALS=true

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Organization Settings
DEFAULT_ORG_ROLE=member
MAX_USERS_PER_ORG=1000
MAX_PLUGINS_PER_ORG=50

# Performance Settings
CACHE_TTL=3600  # 1 hour
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# Monitoring & Health Checks
HEALTH_CHECK_INTERVAL=30
MAX_AI_REQUESTS_PER_MINUTE=60
