{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local",
    "**/.env",
    "**/.env.*"
  ],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**", 
        "build/**", 
        "!.next/cache/**",
        "htmlcov/**",
        "src/aicrm/__pycache__/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**/*.tsx", 
        "src/**/*.ts", 
        "src/**/*.jsx", 
        "src/**/*.js", 
        "test/**/*.ts", 
        "test/**/*.tsx", 
        "test/**/*.js", 
        "test/**/*.jsx", 
        "**/*.test.*", 
        "**/*.spec.*", 
        "**/__tests__/**",
        "*.py",
        "src/**/*.py"
      ],
      "outputs": [
        "coverage/**", 
        ".nyc_output/**", 
        "test-results/**",
        "htmlcov/**",
        ".coverage"
      ]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*",
        "*.py",
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx"
      ]
    },
    "lint:fix": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": true
    },
    "db:migrate": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "db:seed": {
      "cache": false,
      "dependsOn": ["db:migrate"]
    },
    "deploy": {
      "dependsOn": ["build", "test", "lint"],
      "cache": false
    },
    "docker:build": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "docker:push": {
      "dependsOn": ["docker:build"],
      "cache": false
    }
  }
}
