        "security": [{"JWT": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CrmConnectorConfig"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Коннектор успешно настроен"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WorkflowCreateFromPromptRequest": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Текстовое описание бизнес-сценария на естественном языке."
          },
          "name": {
            "type": "string",
            "description": "Человеко-читаемое название workflow. Если не указано, будет сгенерировано ИИ."
          },
          "is_active": {
            "type": "boolean",
            "default": true,
            "description": "Активировать правило сразу после создания."
          }
        }
      },
      "WorkflowDetailResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description_ai": {
            "type": "string",
            "description": "Пояснение от ИИ, как он понял и интерпретировал prompt."
          },
          "trigger": {
            "$ref": "#/components/schemas/TriggerDefinition"
          },
          "conditions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Condition" }
          },
          "actions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Action" }
          },
          "is_active": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "TriggerDefinition": {
        "type": "object",
        "properties": {
          "event_type": {
            "type": "string",
            "enum": ["ON_ORDER_CREATED", "ON_LEAD_ADD", "ON_PRODUCTION_STEP_COMPLETE", "ON_CUSTOMER_CREATED", "ON_DEAL_STATUS_CHANGED"],
            "description": "Тип события из основной CRM."
          }
        }
      },
      "Condition": {
        "type": "object",
        "properties": {
          "field_path": {
            "type": "string",
            "description": "Путь к полю в event.payload (e.g., 'order.total', 'customer.city')."
          },
          "operator": {
            "type": "string",
            "enum": ["eq", "gt", "lt", "contains", "in", "exists"],
            "description": "Оператор сравнения."
          },
          "value": {
            "type": ["string", "number", "boolean", "array", "null"],
            "description": "Значение для сравнения."
          }
        }
      },
      "Action": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["send_notification", "create_task", "update_entity", "call_ai", "make_http_request"]
          },
          "config": {
            "type": "object",
            "description": "Конфигурация действия, зависит от type."
          }
        }
      },
      "IncomingEvent": {
        "type": "object",
        "required": ["event_type", "entity_type", "entity_id", "payload"],
        "properties": {
          "event_id": { "type": "string" },
          "event_type": { "type": "string" },
          "entity_type": { "type": "string" },
          "entity_id": { "type": ["integer", "string"] },
          "payload": { "type": "object" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "CrmConnectorConfig": {
        "type": "object",
        "required": ["base_url", "api_key"],
        "properties": {
          "base_url": { "type": "string", "format": "uri", "example": "https://api.your-crm.com/v1" },
          "api_key": { "type": "string" },
          "auth_type": { "type": "string", "enum": ["bearer", "api_key_header"], "default": "bearer" }
        }
      }
    },
    "securitySchemes": {
      "JWT": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT-токен, выданный основной CRM. В payload должна быть информация о пользователе и его ролях."
      },
      "InternalWebhookAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Webhook-Secret",
        "description": "Секретный ключ, которым основная CRM подписывает свои вебхуки для защиты от подделок."
      }
    }
  }
}