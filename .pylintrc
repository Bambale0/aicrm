е[MASTER]
# Use multiple processes to speed up Pylint.
jobs=0

# Python code to execute, usually for sys.path manipulation
init-hook='import sys; sys.path.append(".")'

[MESSAGES CONTROL]
# Disable some messages that are not useful in our context
disable=
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    R0914,  # too-many-locals
    R0915,  # too-many-statements
    W0613,  # unused-argument (often used in FastAPI)
    W0718,  # broad-exception-caught
    W0719,  # broad-exception-raised
    C0103,  # invalid-name (allow snake_case)
    C0209,  # consider-using-f-string (sometimes not necessary)
    E501,   # line-too-long (handled by black)
    W503,   # line-break-before-binary-operator (handled by black)
    W504,   # line-break-after-binary-operator (handled by black)

[REPORTS]
# Set the output format
output-format=text

# Template used to display messages
msg-template='{path}:{line}:{column}: [{msg_id}({symbol}), {obj}] {msg}'

[BASIC]
# Naming style matching the regex '^[a-z_][a-z0-9_]*$'
function-rgx=^[a-z_][a-z0-9_]*$
variable-rgx=^[a-z_][a-z0-9_]*$
const-rgx=^[a-zA-Z_][a-zA-Z0-9_]*$
class-rgx=^[A-Z_][a-zA-Z0-9]*$
method-rgx=^[a-z_][a-z0-9_]*$
attr-rgx=^[a-z_][a-z0-9_]*$

# Good variable names which should always be accepted, separated by a comma
good-names=i,j,k,ex,Run,_,db,fs,id,ip,ok,url,api,app,ctx,log

[FORMAT]
# Maximum number of characters on a single line
max-line-length=88

# String used as indentation unit
indent-string='    '

[SIMILARITIES]
# Minimum lines number of a similarity
min-similarity-lines=4

# Ignore comments when computing similarities
ignore-comments=yes

# Ignore docstrings when computing similarities
ignore-docstrings=yes

# Ignore imports when computing similarities
ignore-imports=no

[DESIGN]
# Maximum number of arguments for function / method
max-args=8

# Maximum number of locals for function / method body
max-locals=20

# Maximum number of return / yield for function / method body
max-returns=6

# Maximum number of branch for function / method body
max-branches=12

# Maximum number of statements in function / method body
max-statements=50

# Maximum number of parents for a class (see R0901)
max-parents=7

[IMPORTS]
# Allow wildcard imports from these modules
allow-wildcard-with-all=no

[TYPECHECK]
# List of decorators that produce context managers, such as contextlib.contextmanager
contextmanager-decorators=contextlib.contextmanager

# List of members which are set dynamically and missed by pylint inference system
generated-members=REQUEST,acl_users,aq_parent,objects,DoesNotExist,id,pk,_meta,base_fields,context,registry,_registry,_serializer,Meta,objects,get_or_create,update_or_create,bulk_create,bulk_update,select_related,prefetch_related,annotate,aggregate,distinct,order_by,values,values_list,exists,count,first,last,filter,exclude,union,intersection,difference,extra,raw,using,select_for_update,defer,only,iterator,chunked_read,transaction,atomic,savepoint,rollback,commit,autocommit,timezone,now,case,when,value,func,window,row_number,lag,lead,ntile,percent_rank,cume_dist,dense_rank,rank,first_value,last_value,nth_value,extract,trunc,date,datetime,time,interval,pi,power,sqrt,exp,ln,log,sin,cos,tan,asin,acos,atan,atan2,radians,degrees,sign,random,uuid,md5,sha1,sha224,sha256,sha384,sha512,encode,decode,length,substring,upper,lower,trim,ltrim,rtrim,replace,regexp_replace,regexp_match,regexp_split,concat,concat_ws,string_agg,array_agg,json_agg,json_build_object,json_object,json_array,jsonb_agg,jsonb_build_object,jsonb_object,jsonb_array,json_extract_path,json_extract_path_text,jsonb_extract_path,jsonb_extract_path_text,json_set,jsonb_set,json_strip_nulls,jsonb_strip_nulls,json_typeof,jsonb_typeof,to_json,to_jsonb,array_to_json,json_array_elements,jsonb_array_elements,json_array_elements_text,jsonb_array_elements_text,json_object_keys,jsonb_object_keys,json_each,jsonb_each,json_each_text,jsonb_each_text,json_populate_record,jsonb_populate_record,json_to_record,jsonb_to_record,tsvector,tsquery,to_tsvector,to_tsquery,ts_rank,ts_rank_cd,ts_headline,phraseto_tsquery,websearch_to_tsquery,ts_rewrite,tsquery_phrase,ts_delete,ts_filter,unnest,generate_series,generate_subscripts,width_bucket,mode,percentile_cont,percentile_disc,stddev,stddev_pop,stddev_samp,var_pop,var_samp,variance,regr_avgx,regr_avgy,regr_count,regr_intercept,regr_r2,regr_slope,regr_sxx,regr_sxy,regr_syy,corr,covar_pop,covar_samp,num_nonnulls,num_nulls,last_value,first_value,nth_value,row_number,rank,dense_rank,percent_ra